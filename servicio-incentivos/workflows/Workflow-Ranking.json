    {
      "parameters": {
        "jsCode": "const data = items.map(i => i.json);\n\n// 1. Agrupar por donante\nconst grouped = {};\n\nfor (const d of data) {\n  if (!grouped[d.donanteId]) {\n    grouped[d.donanteId] = {\n      donanteId: d.donanteId,\n      nombre: d.nombre,\n      misiones: 0,\n      impacto: 0\n    };\n  }\n\n  grouped[d.donanteId].misiones += 1;\n  grouped[d.donanteId].impacto += d.impacto;\n}\n\n// 2. Convertir a array\nlet result = Object.values(grouped);\n\n// 3. Ordenar ranking\nresult.sort((a, b) => b.impacto - a.impacto);\n\n// 4. Agregar rank\nresult = result.map((r, index) => ({\n  ...r,\n  rank: index + 1\n}));\n\n// 5. agregar mes + sheetName\nconst mes = new Date().toISOString().slice(0,7);\nconst sheetName = `ranking_${mes}`;\n\nreturn result.map(r => ({\n  json: {\n    ...r,\n    mes,\n    sheetName\n  }\n}));"
      },
